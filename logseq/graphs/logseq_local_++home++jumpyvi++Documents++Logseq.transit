l restart libvirtd.service``\n\t- Fix network not working: set `firewall_backend=iptables` in `/etc/libvirt/network.conf`\n\t- Fix qemu [[Linux User]] not existing (Silverblue):\n\t\t- ``sudo groupadd qemu``\n\t\t- ``sudo useradd -r -g qemu -M -s /sbin/nologin qemu``\n\t- Fix virtlogd with SELinux\n\t\t- ``sudo audit2allow -a -M virtlogd_fix``\n\t\t- ``sudo semodule -i virtlogd_fix.pp``\n\t\t- ``sudo restorecon -R /var/log/libvirt/qemu``\n\t\t-",536870916]],["^15",[126,"^16",1737421467460,536870916]],["^15",[126,"^Z","pages/Virtualization.md",536870916]],["^15",[127,"^K",1737421467459,536870916]],["^15",[127,"^[",126,536870916]],["^15",[127,"^@",false,536870916]],["^15",[127,"^Y","virtualization",536870916]],["^15",[127,"^11","Virtualization",536870916]],["^15",[127,"^B",1737421467459,536870916]],["^15",[127,"^;","~u678ef29b-1ed8-4fa6-85f6-6d5033898090",536870916]],["^15",[128,"^K",1737421467460,536870916]],["^15",[128,"^@",false,536870916]],["^15",[128,"^Y","linux user",536870916]],["^15",[128,"^11","Linux User",536870916]],["^15",[128,"^B",1737421467460,536870916]],["^15",[128,"^;","~u678ef29b-64be-49cd-8033-f9d42d7bf986",536870916]],["^15",[129,"^Q","~``sudo groupadd --system libvirt``",536870916]],["^15",[129,"^O","^17",536870916]],["^15",[129,"^F",130,536870916]],["^15",[129,"^X",127,536870916]],["^15",[129,"^V",130,536870916]],["^15",[129,"^U",127,536870916]],["^15",[129,"^;","~u678ef29b-9ac9-4066-a160-c3a7376c2722",536870916]],["^15",[130,"^Q","Use as regular user:",536870916]],["^15",[130,"^O","^17",536870916]],["^15",[130,"^F",141,536870916]],["^15",[130,"^X",127,536870916]],["^15",[130,"^V",141,536870916]],["^15",[130,"^U",127,536870916]],["^15",[130,"^;","~u678ef29b-3145-49cd-ab05-1f89f9394719",536870916]],["^15",[131,"^Q","",536870916]],["^15",[131,"^O","^17",536870916]],["^15",[131,"^F",138,536870916]],["^15",[131,"^X",127,536870916]],["^15",[131,"^V",139,536870916]],["^15",[131,"^U",127,536870916]],["^15",[131,"^;","~u678ef29b-a64f-42d1-9365-0cbd61e460