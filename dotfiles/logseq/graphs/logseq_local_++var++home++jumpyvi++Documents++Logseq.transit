 virtlogd_fix.pp``\n\t\t- ``sudo restorecon -R /var/log/libvirt/qemu``\n\t\t-",536870919]],["^15",[116,"^17",1736812195862,536870919]],["^15",[116,"^Z","pages/Virtualization.md",536870919]],["^15",[117,"^K",1736812195861,536870919]],["^15",[117,"^[",116,536870919]],["^15",[117,"^@",false,536870919]],["^15",[117,"^Y","virtualization",536870919]],["^15",[117,"^11","Virtualization",536870919]],["^15",[117,"^B",1736812195861,536870919]],["^15",[117,"^;","~u6785a6a3-3451-4885-97fc-2110a320652e",536870919]],["^15",[118,"^K",1736812195861,536870919]],["^15",[118,"^@",false,536870919]],["^15",[118,"^Y","linux user",536870919]],["^15",[118,"^11","Linux User",536870919]],["^15",[118,"^B",1736812195861,536870919]],["^15",[118,"^;","~u6785a6a3-7e4a-4a73-8b90-fed3e5ebfa3b",536870919]],["^15",[119,"^Q","~``sudo groupadd qemu``",536870919]],["^15",[119,"^O","^16",536870919]],["^15",[119,"^F",122,536870919]],["^15",[119,"^X",117,536870919]],["^15",[119,"^V",122,536870919]],["^15",[119,"^U",117,536870919]],["^15",[119,"^U",118,536870919]],["^15",[119,"^;","~u6785a6a3-f34e-425f-899e-f680c516a5c4",536870919]],["^15",[120,"^Q","**Qemu/KVM**",536870919]],["^15",[120,"^O","^16",536870919]],["^15",[120,"^F",117,536870919]],["^15",[120,"^X",117,536870919]],["^15",[120,"^V",117,536870919]],["^15",[120,"^U",117,536870919]],["^15",[120,"^;","~u6785a6a3-ed98-4302-9403-5a0f56867bf2",536870919]],["^15",[121,"^Q","~``sudo useradd -r -g qemu -M -s /sbin/nologin qemu``",536870919]],["^15",[121,"^O","^16",536870919]],["^15",[121,"^F",119,536870919]],["^15",[121,"^X",117,536870919]],["^15",[121,"^V",122,536870919]],["^15",[121,"^U",117,536870919]],["^15",[121,"^U",118,536870919]],["^15",[121,"^;","~u6785a6a3-da81-4b63-b576-e0e99c8e7282",536870919]],["^15",[122,"^Q","Fix qemu [[Linux User]] not existing (Silverblue):",536870919]],["^15",[122,"^O","^16",536870919]],["^15",[122,"^F",130,536870919]],["^15",[122,"^X",117,536870919]],["^15",[122,"^V",120,536870919]],["^15",[122,"^U",117,536870919]],["^15",